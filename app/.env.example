# Server
PORT=3000

# Minut (global, ein Account fuer alle Wohnungen)
MINUT_CLIENT_ID=
MINUT_CLIENT_SECRET=

# Nuki (global, ein API-Token fuer alle Wohnungen)
NUKI_API_TOKEN=

# Tado-Zugangsdaten werden NICHT hier hinterlegt.
# Sie stehen pro Wohnung in config/apartments.json,
# da jede Wohnung einen eigenen Tado-Account haben kann.
